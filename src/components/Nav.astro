---
const links = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#writing', label: 'Writing' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="site-nav fixed inset-x-0 top-0 z-50 border-b">
  <nav
    class="mx-auto flex h-16 max-w-2xl items-center justify-between px-6"
    aria-label="Primary"
  >
    <a
      href="#top"
      class="font-serif text-lg font-semibold tracking-tight text-current transition-opacity hover:opacity-70"
    >
      Dmitry Uchakin
    </a>

    <div class="flex items-center gap-6">
      <ul class="hidden items-center gap-6 text-sm sm:flex">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-current/75 transition-colors hover:text-accent"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <button
        id="theme-toggle"
        type="button"
        class="-m-2 rounded-md p-2 text-current/75 transition-colors hover:text-accent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        aria-label="Toggle color theme"
        title="Toggle light / dark"
      >
        <svg
          class="hidden h-5 w-5 dark:block"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32 1.41-1.41"
          ></path>
        </svg>
        <svg
          class="h-5 w-5 dark:hidden"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  // Theme toggle
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // Nav goes from transparent (over the ocean hero) to solid once scrolled past it.
  // The hero (#top) lives in <main>, parsed after this script, so query it lazily.
  (() => {
    const nav = document.querySelector('.site-nav');
    if (!nav) return;
    const update = () => {
      const hero = document.getElementById('top');
      const threshold = hero ? Math.max(0, hero.offsetHeight - 80) : 0;
      nav.classList.toggle('is-solid', window.scrollY > threshold);
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    window.addEventListener('DOMContentLoaded', update);
  })();
</script>
